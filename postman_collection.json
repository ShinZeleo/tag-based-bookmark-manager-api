{
  "info": {
    "name": "Tag-Based Bookmark Manager API",
    "description": "# Tag-Based Bookmark Manager API\n\nA secure REST API for managing personal bookmarks with tagging functionality.\n\n## Base URL:\n`{{base_url}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://tag-based-bookmark-manager-api.onrender.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookmark_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "tag_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user{{$randomInt}}@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register a new user. Uses random email for clean testing."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "user@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "securepassword123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Bookmarks",
      "item": [
        {
          "name": "Create Bookmark",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 201 && jsonData.id) {",
                  "    pm.collectionVariables.set(\"bookmark_id\", jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"FastAPI Docs\",\n  \"url\": \"https://fastapi.tiangolo.com/\",\n  \"tags\": [\"python\", \"api\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookmarks",
                ""
              ]
            }
          }
        },
        {
          "name": "Get All Bookmarks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookmarks",
                ""
              ]
            }
          }
        },
        {
          "name": "Get Bookmark by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/{{bookmark_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookmarks",
                "{{bookmark_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Bookmark",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Bookmark Title\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks/{{bookmark_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookmarks",
                "{{bookmark_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Bookmark",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/{{bookmark_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookmarks",
                "{{bookmark_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Tags",
      "item": [
        {
          "name": "Create Tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 201 && jsonData.id) {",
                  "    pm.collectionVariables.set(\"tag_id\", jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"machine learning {{$randomInt}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tags/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tags",
                ""
              ]
            }
          }
        },
        {
          "name": "Get All Tags",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tags/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tags",
                ""
              ]
            }
          }
        },
        {
          "name": "Update Tag",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"deep learning\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tags/{{tag_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tags",
                "{{tag_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Tag",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tags/{{tag_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tags",
                "{{tag_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}