{
  "info": {
    "name": "Tag-Based Bookmark Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "testuser@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "securepassword123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Bookmarks",
      "item": [
        {
          "name": "Create Bookmark",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"FastAPI Official Docs\",\n  \"url\": \"https://fastapi.tiangolo.com/\",\n  \"description\": \"Great framework for Python APIs\",\n  \"tags\": [\"python\", \"fastapi\", \"api\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks/",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", ""]
            }
          }
        },
        {
          "name": "Get All Bookmarks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", ""]
            }
          }
        },
        {
          "name": "Get Bookmark by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/1",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", "1"]
            }
          }
        },
        {
          "name": "Update Bookmark",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"FastAPI Docs (Updated)\",\n  \"description\": \"Updated description\",\n  \"tags\": [\"python\", \"fastapi\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks/1",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", "1"]
            }
          }
        },
        {
          "name": "Delete Bookmark",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/1",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Tags",
      "item": [
        {
          "name": "Create Tag",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"machine learning\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tags/",
              "host": ["{{base_url}}"],
              "path": ["tags", ""]
            }
          }
        },
        {
          "name": "Get All Tags",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tags/",
              "host": ["{{base_url}}"],
              "path": ["tags", ""]
            }
          }
        },
        {
          "name": "Update Tag",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"deep learning\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tags/1",
              "host": ["{{base_url}}"],
              "path": ["tags", "1"]
            }
          }
        },
        {
          "name": "Delete Tag",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tags/1",
              "host": ["{{base_url}}"],
              "path": ["tags", "1"]
            }
          }
        }
      ]
    }
  ]
}
